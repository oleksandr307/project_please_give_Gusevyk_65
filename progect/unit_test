import unittest
import json
import base64
from script1 import process_request

class TestServerLogic(unittest.TestCase):

    def test_arithmetic_valid(self):
        req = json.dumps({"task": "arithmetic", "expression": "(2+3)*4"})
        resp = json.loads(process_request(req))
        self.assertIn("result", resp)
        self.assertAlmostEqual(resp["result"], 20.0)

    def test_arithmetic_invalid_chars(self):
        req = json.dumps({"task": "arithmetic", "expression": "2+3; import os"})
        resp = json.loads(process_request(req))
        self.assertIn("error", resp)

    def test_linear_equation(self):
        req = json.dumps({"task": "linear", "a": 4, "b": -7})
        resp = json.loads(process_request(req))
        self.assertIn("result", resp)
        self.assertEqual(resp["result"], "x = 1.7500")

    def test_linear_zero_a(self):
        req = json.dumps({"task": "linear", "a": 0, "b": 5})
        resp = json.loads(process_request(req))
        self.assertIn("error", resp)

    def test_quadratic_two_roots(self):
        req = json.dumps({"task": "quadratic", "a": 2, "b": -3, "c": -5})
        resp = json.loads(process_request(req))
        self.assertIn("result", resp)
        self.assertIn("x1 = ", resp["result"])
        self.assertIn("x2 = ", resp["result"])

    def test_quadratic_no_real_roots(self):
        req = json.dumps({"task": "quadratic", "a": 1, "b": 0, "c": 1})
        resp = json.loads(process_request(req))
        self.assertIn("result", resp)
        self.assertEqual(resp["result"], "Дійсних коренів немає")

    def test_statistics(self):
        req = json.dumps({"task": "statistics", "numbers": [12, 7, 5, 9, 12, 15, 8, 9, 12]})
        resp = json.loads(process_request(req))
        self.assertIn("result", resp)
        stats = resp["result"]
        self.assertAlmostEqual(stats["mean"], 9.8889, places=4)
        self.assertAlmostEqual(stats["median"], 9.0)
        self.assertEqual(stats["mode"], 12)

    def test_plot(self):
        req = json.dumps({"task": "plot", "function": "sin(x)", "x_min": -3.14, "x_max": 3.14})
        resp = json.loads(process_request(req))
        self.assertIn("image", resp)
        img_bytes = base64.b64decode(resp["image"])
        self.assertTrue(len(img_bytes) > 0)

    def test_linear_programming(self):
        req = json.dumps({
            "task": "lp",
            "c": [3, 2],
            "A_ub": [[1, 1], [2, 1]],
            "b_ub": [4, 5]
        })
        resp = json.loads(process_request(req))
        self.assertIn("result", resp)
        sol = resp["result"]
        self.assertIn("x", sol)
        self.assertIn("z", sol)
        self.assertAlmostEqual(sol["z"], 11.0, places=1)

    def test_least_squares(self):
        req = json.dumps({
            "task": "ls",
            "X": [[1, 1], [1, 2], [1, 3], [1, 4], [1, 5]],
            "y": [2, 3, 5, 4, 6]
        })
        resp = json.loads(process_request(req))
        self.assertIn("result", resp)
        coeffs = resp["result"]
        self.assertEqual(len(coeffs), 2)
        self.assertAlmostEqual(coeffs[0], 1.6, places=1)
        self.assertAlmostEqual(coeffs[1], 0.9, places=1)

    def test_random_task(self):
        req = json.dumps({"task": "random_task"})
        resp = json.loads(process_request(req))
        self.assertIn("task_text", resp)
        self.assertTrue(len(resp["task_text"]) > 0)

    def test_unknown_task(self):
        req = json.dumps({"task": "unknown"})
        resp = json.loads(process_request(req))
        self.assertIn("error", resp)

    def test_invalid_json(self):
        resp = json.loads(process_request("not a json"))
        self.assertIn("error", resp)

if __name__ == "__main__":
    unittest.main()
